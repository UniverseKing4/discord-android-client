<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Message Scheduler"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"/>

            <EditText
                android:id="@+id/tokenInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Token"
                android:inputType="textPassword"/>

            <EditText
                android:id="@+id/channelInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Channel ID"
                android:inputType="number"/>

            <EditText
                android:id="@+id/messageInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Message"
                android:minLines="2"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Timer"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/hoursInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Hours"
                    android:inputType="number"
                    android:text="0"/>

                <EditText
                    android:id="@+id/minutesInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Minutes"
                    android:inputType="number"
                    android:text="0"
                    android:layout_marginStart="8dp"/>

                <EditText
                    android:id="@+id/secondsInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Seconds"
                    android:inputType="number"
                    android:text="0"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

            <CheckBox
                android:id="@+id/intervalToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Repeat (Interval)"/>

            <CheckBox
                android:id="@+id/backgroundToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Background Mode (works when app closed)"/>

            <Button
                android:id="@+id/addBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Add Scheduled Message"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scheduled Messages"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/scheduledList"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:minHeight="200dp"
                android:layout_marginTop="8dp"/>
        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/masterBtn"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:text="STOP"
        android:textSize="11sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:singleLine="true"
        android:ellipsize="none"
        android:elevation="8dp"/>
</FrameLayout>
